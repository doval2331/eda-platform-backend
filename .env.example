# SQLite (sin Docker). Para PostgreSQL con Docker: ver .env.docker.example
DATABASE_URL=sqlite:///./eda_platform.db
# DATABASE_URL=postgresql+psycopg2://eda:eda_local_dev@127.0.0.1:5432/eda_platform

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

DEFAULT_SEED=42
DEFAULT_N_SAMPLES=2000
IT_OPS_DATASET_PATH=data/it_ops_synthetic_10000.csv
UPLOADS_DIR=data/uploads
MAX_UPLOAD_BYTES=15728640
DUCKDB_PATH=data/eda_platform.duckdb
BI_SYNC_ENABLED=false
BI_DATABASE_URL=postgresql+psycopg2://eda:eda_local_dev@127.0.0.1:5432/eda_platform
METABASE_URL=http://localhost:3000
METABASE_DASHBOARD_URL=
METABASE_USERNAME=
METABASE_PASSWORD=
METABASE_DATABASE_NAME=TFM IT Analytics
METABASE_DASHBOARD_NAME=Dashboard IT - Evidencias conversacionales
METABASE_PG_HOST=postgres
METABASE_PG_PORT=5432
METABASE_PG_DBNAME=eda_platform
METABASE_PG_USER=eda
METABASE_PG_PASSWORD=eda_local_dev

# LLM opcional. Apagado por defecto: el chat sigue usando reglas locales.
# Para activarlo, define LLM_ENABLED=true y configura un proveedor compatible con OpenAI.
# El LLM solo recibe resumenes agregados e insights candidatos, no filas completas.
LLM_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=20

# Alternativa local con Ollama, sin API externa:
# LLM_API_BASE=http://127.0.0.1:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:1.5b
# LLM_TIMEOUT_SECONDS=120

JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=480
DEMO_USER_EMAIL=analista@tfm.local
DEMO_USER_PASSWORD=TfmDemo2026!
DEMO_USER_NOMBRE=Analista TFM
